  <worksheets>
    <worksheet name='Task 1: Delivery Performance Classification'>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.0to8ojm0lkk11p1h22p5p0s2xi7w' />
          </datasources>
          <datasource-dependencies datasource='federated.0to8ojm0lkk11p1h22p5p0s2xi7w'>
            <column caption='Delivery Status' datatype='string' name='[Calculation_0553929753792512]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Delivery_Time_Min] &lt;= 30 THEN &quot;FAST&quot;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;END' />
            </column>
            <column caption='Delivery Time Min' datatype='integer' name='[Delivery_Time_Min]' role='measure' type='quantitative' />
            <column caption='Order ID' datatype='integer' name='[Order_ID]' role='dimension' type='ordinal' />
            <column-instance column='[Order_ID]' derivation='Count' name='[cnt:Order_ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0553929753792512]' derivation='None' name='[none:Calculation_0553929753792512:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
          </pane>
        </panes>
        <rows>[federated.0to8ojm0lkk11p1h22p5p0s2xi7w].[none:Calculation_0553929753792512:nk]</rows>
        <cols>[federated.0to8ojm0lkk11p1h22p5p0s2xi7w].[cnt:Order_ID:qk]</cols>
      </table>
      <simple-id uuid='{79A5CDF4-7F51-491A-902B-E7A174A447AD}' />
    </worksheet>
    <worksheet name='Task 2: Loss-Making Orders Identification'>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.0to8ojm0lkk11p1h22p5p0s2xi7w' />
          </datasources>
          <datasource-dependencies datasource='federated.0to8ojm0lkk11p1h22p5p0s2xi7w'>
            <column caption='Profit Status' datatype='string' name='[Calculation_0553929755766785]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Profit] &lt; 0 THEN &quot;Lose&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
            </column>
            <column caption='Order ID' datatype='integer' name='[Order_ID]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column-instance column='[Order_ID]' derivation='Count' name='[cnt:Order_ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0553929755766785]' derivation='None' name='[none:Calculation_0553929755766785:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
          </pane>
        </panes>
        <rows>[federated.0to8ojm0lkk11p1h22p5p0s2xi7w].[none:Calculation_0553929755766785:nk]</rows>
