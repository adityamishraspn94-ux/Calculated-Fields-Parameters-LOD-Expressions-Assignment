      <aliases enabled='yes' />
      <column caption='Delivery Status' datatype='string' name='[Calculation_0553929753792512]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min] &lt;= 30 THEN &quot;FAST&quot;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit Status' datatype='string' name='[Calculation_0553929755766785]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt; 0 THEN &quot;Lose&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='City Avg Sales (Fixed)' datatype='real' name='[Calculation_0553929757913090]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [City] : AVG([Sales])}' />
      </column>
      <column caption='Product Avg Sales (Include)' datatype='real' name='[Calculation_0553929758773251]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [Product_Name] : AVG([Sales]) }' />
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_0553929762680836]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Sales])) &lt;= [Parameters].[Order ID Parameter]'>
