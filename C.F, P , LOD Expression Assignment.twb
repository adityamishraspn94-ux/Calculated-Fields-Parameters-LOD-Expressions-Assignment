    <worksheet name='Task 3: Top N Products Analysis (Parameter)'>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (Blinkit Orders Dataset)' name='federated.0to8ojm0lkk11p1h22p5p0s2xi7w' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Top N  Products' datatype='integer' name='[Order ID Parameter]' param-domain-type='range' role='measure' type='quantitative' value='2'>
              <calculation class='tableau' formula='2' />
              <range max='20' min='1' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0to8ojm0lkk11p1h22p5p0s2xi7w'>
            <column caption='Top N Filter' datatype='boolean' name='[Calculation_0553929762680836]' role='measure' type='nominal'>
              <calculation class='tableau' formula='RANK(SUM([Sales])) &lt;= [Parameters].[Order ID Parameter]'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Product Name' datatype='string' name='[Product_Name]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Sales]' role='measure' type='quantitative' />
            <column-instance column='[Product_Name]' derivation='None' name='[none:Product_Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Sales]' derivation='Sum' name='[sum:Sales:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0553929762680836]' derivation='User' name='[usr:Calculation_0553929762680836:nk:1]' pivot='key' type='nominal'>
              <table-calc ordering-type='Columns' />
            </column-instance>
          </datasource-dependencies>
          <manual-sort column='[federated.0to8ojm0lkk11p1h22p5p0s2xi7w].[none:Product_Name:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Cold Drink&quot;</bucket>
              <bucket>&quot;Banana&quot;</bucket>
              <bucket>&quot;Juice&quot;</bucket>
              <bucket>&quot;Bread&quot;</bucket>
              <bucket>&quot;Chips&quot;</bucket>
              <bucket>&quot;Milk&quot;</bucket>
              <bucket>&quot;Curd&quot;</bucket>
              <bucket>&quot;Apple&quot;</bucket>
              <bucket>%all%</bucket>
            </dictionary>
          </manual-sort>
          <filter class='categorical' column='[federated.0to8ojm0lkk11p1h22p5p0s2xi7w].[usr:Calculation_0553929762680836:nk:1]'>
            <groupfilter function='member' level='[usr:Calculation_0553929762680836:nk:1]' member='true' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.0to8ojm0lkk11p1h22p5p0s2xi7w].[usr:Calculation_0553929762680836:nk:1]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
        </panes>
        <rows>[federated.0to8ojm0lkk11p1h22p5p0s2xi7w].[none:Product_Name:nk]</rows>
        <cols>[federated.0to8ojm0lkk11p1h22p5p0s2xi7w].[sum:Sales:qk]</cols>
      </table>
      <simple-id uuid='{E9B1ACC2-5A81-442D-AA2B-613BCBCB161F}' />
